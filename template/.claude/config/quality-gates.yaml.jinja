quality_gates:
  authority: .claude/config/quality-gates.yaml
  coverage_threshold: {{ coverage_threshold }}
  branch_coverage: true
  bootstrap:
    commands:
      - uv run python tools/init_scope_memory.py
      - uv run python tools/init_review_state.py
      - uv run python tools/install_pre_commit.py
  lockfile_policy:
    bootstrap_command: uv lock
    commit_required_after_bootstrap: true
    ci_install_mode: prefer_lockfile_when_present
  commands:
    - uv run python tools/verify_scope_memory.py
    - uv run python tools/verify_review_state.py
    - uv run python tools/run_pre_commit.py
    - uv run ruff check .
    - uv run ruff format --check .
    - uv run mypy src tests tools
    - uv run python tools/run_eval_gate.py
    - uv run python tools/run_data_contract_gate.py
    - uv run python tools/run_full_test_suite.py
  evaluation_gate:
    enabled: true
    command: uv run python tools/run_eval_gate.py
    local_quality_gate_behavior: always_run_gate_wrapper
    starter_behavior: run starter eval checks until project surfaces require real eval coverage
    project_specific_required_when:
      - has_model_or_scoring_logic
      - has_prompt_logic
  data_contract_gate:
    enabled: true
    command: uv run python tools/run_data_contract_gate.py
    local_quality_gate_behavior: always_run_gate_wrapper
    starter_behavior: run starter data-contract checks until project surfaces require real contract coverage
    project_specific_required_when:
      - has_data_contract_surfaces
  optimization_support:
    telemetry_init_command: uv run python tools/init_lightning_telemetry.py
    dataset_export_command: uv run python tools/export_lightning_dataset.py
    enable_when: Agent Lightning telemetry is turned on for advisory optimization
  blocked_states:
    - id: missing_dependency
      action: capture_error_and_pause
    - id: missing_secret
      action: capture_error_and_pause
    - id: bootstrap_failure
      action: capture_error_and_pause
    - id: flaky_test
      action: rerun_once_then_escalate
