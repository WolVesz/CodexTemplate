workflow:
  name: scope-driven-review-loop
  stop_condition: no_open_in_scope_findings
  escalation_condition: ambiguous_scope_after_repeated_triage

  control_plane_refs:
    quality_gates: .claude/config/quality-gates.yaml
    review_scope: .claude/config/review-scope.yaml
    trigger_derivation: .claude/config/trigger-derivation.yaml
    finding_contract: .claude/config/finding-contract.yaml
    finding_quality: .claude/policies/finding-quality.md
    lightning: .claude/config/lightning.yaml
    telemetry: .claude/config/telemetry.yaml
    lightning_boundaries: .claude/policies/lightning-boundaries.md

  phases:
    - id: scope_intake
      agent: scope-intent
      purpose: confirm intent, capture clarifications, and update canonical scope memory
      entry_criteria:
        - scope request exists
      exit_criteria:
        - scope thread selected or created
        - canonical scope snapshot is current
    - id: implementation
      agent: execution
      purpose: implement only the approved scope
      optimization_surface: execution
      entry_criteria:
        - canonical scope snapshot is current
      exit_criteria:
        - change summary is recorded
    - id: local_quality_gate
      agent: execution
      purpose: run lint, format, type, and test gates before reviewer fan-out
      entry_criteria:
        - implementation change summary exists
        - bootstrap completed or local state already initialized
      exit_criteria:
        - all required commands passed or a blocked state was recorded
    - id: review_mode_selection
      agent: scope-intent
      purpose: choose delta review for small changes or full review for milestone changes
      optimization_surface: review_mode_selection
      entry_criteria:
        - local quality gate passed
      exit_criteria:
        - review mode is recorded for the current run
    - id: qa_review_fanout
      agent: reviewers
      purpose: run enabled reviewers whose activation rules match the current review context, or all reviewers during full review
      optimization_surface: reviewer_quality
      entry_criteria:
        - review mode is recorded
      exit_criteria:
        - normalized reviewer findings are stored
    - id: scope_triage
      agent: scope-triage
      purpose: classify findings as in-scope or out-of-scope
      entry_criteria:
        - normalized reviewer findings are stored
      exit_criteria:
        - every finding has a scope status and rationale
    - id: remediation
      agent: remediation
      purpose: fix every in-scope finding and rerun local quality gates
      optimization_surface: remediation
      entry_criteria:
        - every finding has a scope status and rationale
      exit_criteria:
        - no open in-scope findings remain or escalation was triggered
    - id: completion_check
      agent: scope-intent
      purpose: verify that no in-scope findings remain open
      entry_criteria:
        - remediation pass completed
      exit_criteria:
        - loop terminated or next iteration started

  review:
    policy_ref: .claude/config/review-scope.yaml
    trigger_derivation_ref: .claude/config/trigger-derivation.yaml
    finding_contract_ref: .claude/config/finding-contract.yaml
    activation_semantics: any_trigger_or_matching_path
    milestone_mode: full

  optimization:
    lightning_ref: .claude/config/lightning.yaml
    telemetry_ref: .claude/config/telemetry.yaml
    boundaries_ref: .claude/policies/lightning-boundaries.md
    trainable_surfaces:
      - execution
      - reviewer_quality
      - review_mode_selection
      - remediation
    protected_surfaces:
      - scope-intent
      - scope-triage
      - hard-governance
    cost_priority:
      primary_metric: llm_query_count_to_full_qa_pass
      secondary_metric: estimated_llm_cost_usd_to_full_qa_pass
      constraint: preserve_full_qa_pass_integrity

  loop_guards:
    max_iterations_before_escalation: 6
    deduplicate_findings_by:
      - reviewer_id
      - category
      - file_path
      - line_start
      - normalized_evidence
    terminate_only_when:
      - local_quality_gate_passed
      - no_open_in_scope_findings
    blocked_state_policy:
      missing_dependency: capture_error_and_pause
      missing_secret: capture_error_and_pause
      bootstrap_failure: capture_error_and_pause
      flaky_test: rerun_once_then_escalate

  escalation:
    owner: scope-intent
    artifact: .claude/logs/escalation-report.md
    required_fields:
      - iteration
      - blocker
      - impacted_findings
      - attempted_actions
      - requested_input

  reviewer_output_contract:
    authority_ref: .claude/config/finding-contract.yaml
    require_line_numbers_for:
      - static_file_findings
    require_scope_anchor_for:
      - in_scope_claims
