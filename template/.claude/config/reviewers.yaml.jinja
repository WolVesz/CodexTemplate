reviewers:
  - id: ai-engineer
    enabled: true
    perspective: Prompting, context flow, tool safety, model failure modes, and agent behavior.
    prompt: .claude/agents/qa-ai-engineer.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - prompt_or_policy_changed
        - memory_schema_changed
        - tool_or_model_config_changed
      path_globs:
        - .claude/**
        - .codex/**
        - src/**/*agent*
        - src/**/*prompt*
        - tests/**/*agent*
        - tools/**
    owned_categories:
      - prompting
      - context-management
      - tool-use
      - agent-looping
      - model-failure-modes

  - id: solution-architect
    enabled: true
    perspective: Structure, boundaries, abstractions, maintainability, and change resilience.
    prompt: .claude/agents/qa-solution-architect.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - shared_interface_changed
        - architecture_change
        - dependency_manifest_changed
      path_globs:
        - src/**
        - contracts/**
        - .claude/**
        - .codex/**
    owned_categories:
      - architecture
      - modularity
      - dependency-direction
      - maintainability
      - extensibility

  - id: data-scientist
    enabled: true
    perspective: Assumptions, metrics, data edge cases, evaluation rigor, and statistical reasoning.
    prompt: .claude/agents/qa-data-scientist.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - evaluation_logic_changed
        - prompt_or_policy_changed
        - data_contract_changed
      path_globs:
        - contracts/**
        - tests/fixtures/data_contracts/**
        - tests/*data_contract*
        - tests/*eval*
        - tests/**/*data_contract*
        - tests/**/*eval*
        - src/**/*data*
        - src/**/*feature*
        - src/**/*inference*
        - src/**/*metric*
        - src/**/*model*
        - src/**/*pipeline*
        - src/**/*predict*
        - src/**/*rank*
        - src/**/*recommend*
        - src/**/*retrieve*
        - src/**/*score*
        - src/**/*threshold*
    owned_categories:
      - data-assumptions
      - metrics
      - evaluation
      - edge-cases
      - reasoning-gaps

  - id: test-engineer
    enabled: true
    perspective: Missing tests, weak assertions, uncovered branches, and regression coverage.
    prompt: .claude/agents/qa-test-engineer.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - code_changed
        - tests_changed
      path_globs:
        - src/**
        - tests/**
        - tools/**
    owned_categories:
      - test-gap
      - regression-risk
      - assertion-quality
      - branch-coverage
      - edge-case-coverage

  - id: reliability-engineer
    enabled: true
    perspective: Error handling, retries, timeouts, idempotency, and recoverability.
    prompt: .claude/agents/qa-reliability-engineer.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - runtime_behavior_changed
        - ci_workflow_changed
        - tool_or_model_config_changed
      path_globs:
        - .github/workflows/**
        - tools/**
        - src/**/*client*
        - src/**/*service*
        - src/**/*retry*
    owned_categories:
      - resiliency
      - retries
      - timeout-handling
      - idempotency
      - observability

  - id: security-engineer
    enabled: true
    perspective: Secrets, unsafe execution, trust boundaries, injection risks, and privacy.
    prompt: .claude/agents/qa-security-engineer.md
    review_modes: [delta, full]
    activation_mode: any_trigger_or_matching_path
    activation:
      triggers_any:
        - security_sensitive_change
        - tool_or_model_config_changed
        - prompt_or_policy_changed
      path_globs:
        - .env.example
        - src/**/*auth*
        - src/**/*security*
        - src/**/*secret*
        - tools/**
    owned_categories:
      - secrets
      - unsafe-execution
      - prompt-injection
      - data-exposure
      - authorization

severity_rubric_ref: .claude/policies/finding-quality.md
finding_contract_ref: .claude/config/finding-contract.yaml
trigger_authority_ref: .claude/config/review-scope.yaml
trigger_derivation_ref: .claude/config/trigger-derivation.yaml
activation_semantics:
  mode: any_trigger_or_matching_path
  full_review_behavior: run_all_enabled_reviewers

triage_defaults:
  touched_code_correctness_bias: in-scope
  touched_code_test_gap_bias: in-scope
  ambiguous_scope_action: escalate_after_second_pass
