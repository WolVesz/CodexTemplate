project:
  name: "{{ project_name }}"
  distribution_name: "{{ distribution_name }}"
  package_name: "{{ package_name }}"
  description: "{{ project_description }}"
  author: "{{ author_name }}"

scope_memory:
  backend: sqlite
  path: "{{ scope_memory_path }}"
  supported_path_prefixes:
    - .claude/state
    - .codex/state
  schema_version: 2
  thread_table: scope_thread
  canonical_scope_table: scope_snapshot
  clause_table: scope_clause
  event_log_table: scope_event
  migration_table: migration_history
  commit_strategy: append_only_log_with_latest_snapshot
  journaling_mode: wal
  write_strategy: single-writer

review_state:
  backend: sqlite
  path: ".claude/state/review_state.sqlite"
  legacy_path: ".codex/state/review_state.sqlite"
  supported_path_prefixes:
    - .claude/state
    - .codex/state
  schema_version: 1
  run_table: review_run
  finding_table: review_finding
  category_table: review_category
  journaling_mode: wal
  write_strategy: single-writer

models:
  provider:
    name: anthropic
    api_key_env_var: ANTHROPIC_API_KEY
    compatibility_api_key_env_vars:
      - MODEL_PROVIDER_API_KEY
  default:
    env_var: CLAUDE_DEFAULT_MODEL
    fallback_env_vars:
      - CODEX_DEFAULT_MODEL
    temperature: 0.0
    max_tokens: 4000
    timeout_seconds: 120
    retries: 2
    structured_output: true
  scope:
    env_var: CLAUDE_SCOPE_MODEL
    fallback_env_vars:
      - CODEX_SCOPE_MODEL
    inherits: default
  execution:
    env_var: CLAUDE_EXECUTION_MODEL
    fallback_env_vars:
      - CODEX_EXECUTION_MODEL
    inherits: default
  review:
    env_var: CLAUDE_REVIEW_MODEL
    fallback_env_vars:
      - CODEX_REVIEW_MODEL
    inherits: default

quality:
  config_file: .claude/config/quality-gates.yaml
  coverage_threshold: {{ coverage_threshold }}
  branch_coverage: true

optimization:
  lightning_config_file: .claude/config/lightning.yaml
  telemetry_config_file: .claude/config/telemetry.yaml
  boundaries_policy_file: .claude/policies/lightning-boundaries.md

review:
  policy_file: .claude/config/review-scope.yaml
  default_mode: delta
  milestone_mode: full
