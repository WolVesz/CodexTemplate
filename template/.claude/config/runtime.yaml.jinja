project:
  name: "{{ project_name }}"
  distribution_name: "{{ distribution_name }}"
  package_name: "{{ package_name }}"
  description: "{{ project_description }}"
  author: "{{ author_name }}"

scope_memory:
  backend: sqlite
  path: "{{ scope_memory_path }}"
  supported_path_prefixes:
    - .claude/state
    - .codex/state
  schema_version: 2
  thread_table: scope_thread
  canonical_scope_table: scope_snapshot
  clause_table: scope_clause
  event_log_table: scope_event
  migration_table: migration_history
  commit_strategy: append_only_log_with_latest_snapshot
  journaling_mode: wal
  write_strategy: single-writer

review_state:
  backend: sqlite
  path: ".claude/state/review_state.sqlite"
  legacy_path: ".codex/state/review_state.sqlite"
  supported_path_prefixes:
    - .claude/state
    - .codex/state
  schema_version: 1
  run_table: review_run
  finding_table: review_finding
  category_table: review_category
  journaling_mode: wal
  write_strategy: single-writer

compatibility:
  canonical_control_plane_dir: .claude
  provider_entrypoints:
    canonical: CLAUDE.md
    gemini: GEMINI.md
    agents: AGENTS.md
    codex: .codex/manifest.md
  codex_openai:
    support_mode: control_plane_and_model_alias_only
    runtime_provider_supported: false
    model_alias_env_prefix: CODEX_

models:
  provider:
    name: {{ model_provider }}
    supported:
      - anthropic
      - gemini
    api_key_env_var: {% if model_provider == "anthropic" %}ANTHROPIC_API_KEY{% else %}GEMINI_API_KEY{% endif %}
    compatibility_api_key_env_vars:
{% if model_provider == "gemini" %}
      - GOOGLE_API_KEY
{% endif %}
      - MODEL_PROVIDER_API_KEY
  default:
    env_var: {% if model_provider == "anthropic" %}CLAUDE_DEFAULT_MODEL{% else %}GEMINI_DEFAULT_MODEL{% endif %}
    fallback_env_vars:
{% if model_provider == "anthropic" %}
      - GEMINI_DEFAULT_MODEL
{% else %}
      - CLAUDE_DEFAULT_MODEL
{% endif %}
      - CODEX_DEFAULT_MODEL
    temperature: 0.0
    max_tokens: 4000
    timeout_seconds: 120
    retries: 2
    structured_output: true
  scope:
    env_var: {% if model_provider == "anthropic" %}CLAUDE_SCOPE_MODEL{% else %}GEMINI_SCOPE_MODEL{% endif %}
    fallback_env_vars:
{% if model_provider == "anthropic" %}
      - GEMINI_SCOPE_MODEL
{% else %}
      - CLAUDE_SCOPE_MODEL
{% endif %}
      - CODEX_SCOPE_MODEL
    inherits: default
  execution:
    env_var: {% if model_provider == "anthropic" %}CLAUDE_EXECUTION_MODEL{% else %}GEMINI_EXECUTION_MODEL{% endif %}
    fallback_env_vars:
{% if model_provider == "anthropic" %}
      - GEMINI_EXECUTION_MODEL
{% else %}
      - CLAUDE_EXECUTION_MODEL
{% endif %}
      - CODEX_EXECUTION_MODEL
    inherits: default
  review:
    env_var: {% if model_provider == "anthropic" %}CLAUDE_REVIEW_MODEL{% else %}GEMINI_REVIEW_MODEL{% endif %}
    fallback_env_vars:
{% if model_provider == "anthropic" %}
      - GEMINI_REVIEW_MODEL
{% else %}
      - CLAUDE_REVIEW_MODEL
{% endif %}
      - CODEX_REVIEW_MODEL
    inherits: default

quality:
  config_file: .claude/config/quality-gates.yaml
  coverage_threshold: {{ coverage_threshold }}
  branch_coverage: true

optimization:
  lightning_config_file: .claude/config/lightning.yaml
  telemetry_config_file: .claude/config/telemetry.yaml
  boundaries_policy_file: .claude/policies/lightning-boundaries.md

review:
  policy_file: .claude/config/review-scope.yaml
  default_mode: delta
  milestone_mode: full
