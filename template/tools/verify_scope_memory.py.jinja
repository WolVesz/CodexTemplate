from __future__ import annotations

import os
import sqlite3
from pathlib import Path


DEFAULT_DB_PATH = Path("{{ scope_memory_path }}")
EXPECTED_SCHEMA_VERSION = "2"


def resolve_db_path(path_raw: str) -> Path:
    if "\\" in path_raw:
        raise SystemExit("SCOPE_MEMORY_PATH must use forward slashes.")

    db_path = Path(path_raw)
    if db_path.is_absolute() or ".." in db_path.parts:
        raise SystemExit("SCOPE_MEMORY_PATH must stay inside the project under .codex/state/.")

    if tuple(db_path.parts[:2]) != (".codex", "state"):
        raise SystemExit("SCOPE_MEMORY_PATH must stay inside .codex/state/.")

    return db_path


def main() -> None:
    root = Path(__file__).resolve().parents[1]
    db_path = root / resolve_db_path(os.environ.get("SCOPE_MEMORY_PATH", DEFAULT_DB_PATH.as_posix()))

    if not db_path.exists():
        raise SystemExit("Scope memory is missing. Run `uv run python tools/init_scope_memory.py`.")

    connection = sqlite3.connect(db_path)
    try:
        row = connection.execute(
            "SELECT metadata_value FROM schema_metadata WHERE metadata_key = 'schema_version'"
        ).fetchone()
    finally:
        connection.close()

    if row is None or row[0] != EXPECTED_SCHEMA_VERSION:
        raise SystemExit("Scope memory schema version is invalid. Reinitialize the local state.")

    print(f"Verified scope memory at {db_path}")


if __name__ == "__main__":
    main()
