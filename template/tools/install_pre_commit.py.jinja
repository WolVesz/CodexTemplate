from __future__ import annotations

import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


def main() -> None:
    if not (ROOT / ".git").exists():
        print("Skipping pre-commit hook install because this project is not a git repository yet.")
        return

    raise SystemExit(
        subprocess.call([sys.executable, "-m", "pre_commit", "install"], cwd=ROOT)
    )


if __name__ == "__main__":
    main()
