def test_required_reviewers_are_enabled_and_backed_by_prompts() -> None:
    config = read_yaml(".claude/config/reviewers.yaml")
    reviewers = config["reviewers"]
    finding_contract = read_yaml(".claude/config/finding-contract.yaml")["finding_contract"]
    fanout_agent_text = read_text(".claude/agents/reviewers.md")
    review_scope = read_yaml(".claude/config/review-scope.yaml")["review_scope"]
    known_triggers = set(review_scope["known_change_triggers"])

    assert "canonical payload" in fanout_agent_text
    assert "trigger-derivation.yaml" in fanout_agent_text
    assert config["finding_contract_ref"] == ".claude/config/finding-contract.yaml"
    assert config["trigger_derivation_ref"] == ".claude/config/trigger-derivation.yaml"
    assert config["activation_semantics"]["mode"] == "any_trigger_or_matching_path"

    reviewer_ids = [reviewer["id"] for reviewer in reviewers if reviewer["enabled"]]
    assert len(reviewer_ids) == len(set(reviewer_ids))
    assert {
        "ai-engineer",
        "solution-architect",
        "data-scientist",
        "test-engineer",
        "reliability-engineer",
        "security-engineer",
    }.issubset(set(reviewer_ids))

    control_plane_reviewers = {
        reviewer["id"]: reviewer for reviewer in reviewers if reviewer["id"] in {"ai-engineer", "solution-architect"}
    }
    assert ".codex/**" in control_plane_reviewers["ai-engineer"]["activation"]["path_globs"]
    assert ".codex/**" in control_plane_reviewers["solution-architect"]["activation"]["path_globs"]

    for reviewer in reviewers:
        prompt_path = ROOT / reviewer["prompt"]
        assert prompt_path.exists()
        prompt_text = prompt_path.read_text(encoding="utf-8")
        assert ".claude/config/finding-contract.yaml" in prompt_text
        assert reviewer["activation_mode"] == finding_contract["activation_mode"]
        assert reviewer["activation"]["path_globs"]
        assert set(reviewer["activation"]["triggers_any"]).issubset(known_triggers)


