def test_review_scope_and_trigger_derivation_are_consistent() -> None:
    review_scope = read_yaml(".claude/config/review-scope.yaml")["review_scope"]
    trigger_derivation = read_yaml(".claude/config/trigger-derivation.yaml")["trigger_derivation"]
    reviewers = read_yaml(".claude/config/reviewers.yaml")
    workflow = read_yaml(".claude/config/workflow.yaml")["workflow"]
    policy_text = read_text(".claude/policies/review-scope.md")

    assert review_scope["authority"] == ".claude/config/review-scope.yaml"
    assert review_scope["trigger_derivation_ref"] == ".claude/config/trigger-derivation.yaml"
    assert set(review_scope["full_review_triggers"]).issubset(
        set(review_scope["known_change_triggers"])
    )
    assert "architecture_change" in review_scope["full_review_triggers"]
    assert "control_plane_changed" in review_scope["full_review_triggers"]
    assert "memory_schema_changed" in review_scope["full_review_triggers"]
    assert reviewers["trigger_authority_ref"] == ".claude/config/review-scope.yaml"
    assert reviewers["trigger_derivation_ref"] == ".claude/config/trigger-derivation.yaml"
    assert workflow["review"]["trigger_derivation_ref"] == ".claude/config/trigger-derivation.yaml"
    assert "trigger-derivation.yaml" in policy_text

    prompt_or_policy_rule = next(
        rule for rule in trigger_derivation["path_rules"] if rule["trigger"] == "prompt_or_policy_changed"
    )
    control_plane_rule = next(
        rule for rule in trigger_derivation["path_rules"] if rule["trigger"] == "control_plane_changed"
    )
    assert "CLAUDE.md" in prompt_or_policy_rule["matches_any"]
    assert "GEMINI.md" in prompt_or_policy_rule["matches_any"]
    assert ".codex/manifest.md" in prompt_or_policy_rule["matches_any"]
    assert "CLAUDE.md" in control_plane_rule["matches_any"]
    assert "GEMINI.md" in control_plane_rule["matches_any"]
    assert ".codex/manifest.md" in control_plane_rule["matches_any"]

    known_triggers = set(review_scope["known_change_triggers"])
    for section in ("path_rules", "metadata_rules", "derived_rules"):
        for rule in trigger_derivation[section]:
            assert rule["trigger"] in known_triggers


