def test_export_lightning_dataset_rejects_invalid_state() -> None:
    bad_export = run_script(
        EXPORT_SCRIPT,
        LIGHTNING_EVENT_DB_PATH=".codex/state/missing_lightning.sqlite",
        LIGHTNING_DATASET_EXPORT_PATH=".codex/exports/test_lightning_dataset.jsonl",
    )
    bad_path = run_script(
        EXPORT_SCRIPT,
        LIGHTNING_EVENT_DB_PATH=".codex/state/missing_lightning.sqlite",
        LIGHTNING_DATASET_EXPORT_PATH="../bad.jsonl",
    )
    bad_backslashes = run_script(
        EXPORT_SCRIPT,
        LIGHTNING_EVENT_DB_PATH=".codex/state/missing_lightning.sqlite",
        LIGHTNING_DATASET_EXPORT_PATH=".codex\\exports\\bad.jsonl",
    )

    assert bad_export.returncode != 0
    assert "Initialize Lightning telemetry" in bad_export.stderr or (
        "Initialize Lightning telemetry" in bad_export.stdout
    )
    assert bad_path.returncode != 0
    assert "must stay inside the project" in bad_path.stderr or (
        "must stay inside the project" in bad_path.stdout
    )
    assert bad_backslashes.returncode != 0
    assert "must use forward slashes" in bad_backslashes.stderr or (
        "must use forward slashes" in bad_backslashes.stdout
    )
