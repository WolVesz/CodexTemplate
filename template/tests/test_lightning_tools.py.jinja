            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_export.sqlite",
        )
        assert init_result.returncode == 0

        payload = {
            "workflow_name": "scope-driven-review-loop",
            "scope_thread_key": "thread-001",
            "review_mode": "delta",
            "final_status": "completed",
            "total_llm_queries": 12,
            "estimated_llm_cost_usd": 0.48,
            "workload_context": {"change_size": "small", "trigger_mix": ["code_changed"]},
            "review_iterations": 2,
            "closed_in_scope_findings": 3,
            "confirmed_findings": 2,
            "confirmed_finding_precision": 0.66,
            "finding_yield_proxy": 0.50,
            "false_negative_risk_proxy": 0.10,
            "eval_dataset_version": "starter-eval-v1",
            "phase_events": [
                {
                    "phase_id": "implementation",
                    "agent_id": "execution",
                    "action_kind": "enter",
                    "status": "started",
                }
            ],
            "llm_queries": [
                {
                    "phase_id": "implementation",
                    "agent_id": "execution",
                    "model_name": "gpt-5.4",
                    "prompt_version": "execution@v1",
                    "query_kind": "execution",
                    "prompt_tokens": 100,
                    "completion_tokens": 50,
                    "estimated_cost_usd": 0.12,
                }
            ],
            "tool_invocations": [
                {
                    "phase_id": "implementation",
                    "agent_id": "execution",
                    "tool_name": "read",
                    "success": True,
                    "latency_ms": 25,
                }
            ],
            "recommendations": [
                {
                    "surface": "execution",
                    "recommendation_key": "reuse-local-context",
                    "recommendation": {"strategy": "reuse-local-context"},
                    "policy_check_passed": True,
                    "policy_check_ref": ".codex/policies/lightning-boundaries.md#rules",
                    "final_decision": "applied",
                    "rationale": "Saved a second execution pass.",
                    "was_applied": True,
                    "llm_queries_saved_estimate": 2.0,
                    "cost_saved_estimate_usd": 0.08,
                }
            ],
            "rewards": [
                {
                    "surface": "overall",
                    "metric_name": "llm_query_count_to_full_qa_pass",
                    "metric_value": 12.0,
                    "reward_value": 0.75,
                }
            ],
            "adjudications": [
                {
                    "finding_key": "finding-001",
                    "reviewer_id": "test-engineer",
                    "outcome": "confirmed",
                    "confidence": 0.91,
                }
            ],
        }

        payload_path = ROOT / ".codex/exports/test_lightning_payload.json"
        payload_path.write_text(json.dumps(payload), encoding="utf-8")

        record_result = subprocess.run(
            [sys.executable, str(RECORD_SCRIPT), str(payload_path)],
            cwd=ROOT,
            env={
                **os.environ,
                "AGENT_LIGHTNING_ENABLED": "true",
                "LIGHTNING_EVENT_DB_PATH": ".codex/state/test_lightning_export.sqlite",
            },
            capture_output=True,
            text=True,
            check=False,
        )
        assert record_result.returncode == 0

        export_result = subprocess.run(
            [sys.executable, str(EXPORT_SCRIPT)],
            cwd=ROOT,
            env={
                **os.environ,
                "LIGHTNING_EVENT_DB_PATH": ".codex/state/test_lightning_export.sqlite",
                "LIGHTNING_DATASET_EXPORT_PATH": ".codex/exports/test_lightning_dataset.jsonl",
            },
            capture_output=True,
            text=True,
            check=False,
        )

        assert export_result.returncode == 0
        assert export_path.exists()
        exported = [
            json.loads(line)
            for line in export_path.read_text(encoding="utf-8").splitlines()
            if line
        ]
        assert exported[0]["cost_metrics"]["total_llm_queries"] == 1
        assert len(exported[0]["scope_thread_key"]) == 64
        assert exported[0]["workload_context"]["change_size"] == "small"
        assert exported[0]["llm_queries"][0]["model_name"] == "gpt-5.4"
        assert exported[0]["tool_invocations"][0]["tool_name"] == "read"
        assert exported[0]["quality_metrics"]["confirmed_finding_precision"] == 1.0
        assert (
            exported[0]["recommendations"][0]["recommendation_key"]
            == "reuse-local-context"
        )
        assert exported[0]["recommendations"][0]["policy_check_passed"] is True
        assert exported[0]["recommendations"][0]["final_decision"] == "applied"
        assert exported[0]["recommendations"][0]["recommendation"]["strategy"] == "reuse-local-context"
        assert exported[0]["adjudications"][0]["outcome"] == "confirmed"
        assert exported[0]["rewards"][0]["metric_name"] == "llm_query_count_to_full_qa_pass"
    finally:
        cleanup_files(
            db_path,
            db_path.with_name(f"{db_path.name}-wal"),
            db_path.with_name(f"{db_path.name}-shm"),
            export_path,
            ROOT / ".codex/exports/test_lightning_payload.json",
        )


def test_record_lightning_trace_blocks_recommendations_when_disabled() -> None:
    db_path = ROOT / ".codex/state/test_lightning_disabled.sqlite"
    payload_path = ROOT / ".codex/exports/test_lightning_disabled_payload.json"
    cleanup_files(
        db_path,
        db_path.with_name(f"{db_path.name}-wal"),
        db_path.with_name(f"{db_path.name}-shm"),
        payload_path,
    )

    try:
        init_result = run_script(
            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_disabled.sqlite",
        )
        assert init_result.returncode == 0

        payload_path.write_text(
            json.dumps(
                {
                    "workflow_name": "scope-driven-review-loop",
                    "scope_thread_key": "thread-disabled",
                    "review_mode": "delta",
                    "final_status": "completed",
                    "recommendations": [
                        {
                            "surface": "execution",
                            "recommendation_key": "skip-roundtrip",
                            "policy_check_passed": True,
                            "policy_check_ref": ".codex/policies/lightning-boundaries.md#rules",
                            "final_decision": "applied",
                            "rationale": "Would skip an extra query.",
                            "was_applied": True,
                        }
                    ],
                }
            ),
            encoding="utf-8",
        )

        result = subprocess.run(
            [sys.executable, str(RECORD_SCRIPT), str(payload_path)],
            cwd=ROOT,
            env={
                **os.environ,
                "LIGHTNING_EVENT_DB_PATH": ".codex/state/test_lightning_disabled.sqlite",
                "LIGHTNING_TELEMETRY_ENABLED": "true",
            },
            capture_output=True,
            text=True,
            check=False,
        )

        assert result.returncode == 0
        connection = sqlite3.connect(db_path)
        try:
            row = connection.execute(
                "SELECT policy_blocked, policy_check_passed, blocked_by_rule, final_decision "
                "FROM optimization_recommendation"
            ).fetchone()
        finally:
            connection.close()

        assert row == (1, 0, "AGENT_LIGHTNING_ENABLED=false", "blocked")
    finally:
        cleanup_files(
            db_path,
            db_path.with_name(f"{db_path.name}-wal"),
            db_path.with_name(f"{db_path.name}-shm"),
            payload_path,
        )


def test_record_lightning_trace_skips_when_telemetry_and_lightning_are_disabled() -> None:
    db_path = ROOT / ".codex/state/test_lightning_skip.sqlite"
    payload_path = ROOT / ".codex/exports/test_lightning_skip_payload.json"
    cleanup_files(
        db_path,
        db_path.with_name(f"{db_path.name}-wal"),
        db_path.with_name(f"{db_path.name}-shm"),
        payload_path,
    )

    try:
        init_result = run_script(
            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_skip.sqlite",
        )
        assert init_result.returncode == 0

        payload_path.write_text(
            json.dumps(
                {
                    "workflow_name": "scope-driven-review-loop",
                    "scope_thread_key": "thread-skip",
                    "review_mode": "delta",
                    "final_status": "completed",
                }
            ),
            encoding="utf-8",
        )

        result = subprocess.run(
            [sys.executable, str(RECORD_SCRIPT), str(payload_path)],
            cwd=ROOT,
            env={**os.environ, "LIGHTNING_EVENT_DB_PATH": ".codex/state/test_lightning_skip.sqlite"},
            capture_output=True,
            text=True,
            check=False,
        )

        assert result.returncode == 0
        assert "telemetry disabled" in result.stdout.lower()
        connection = sqlite3.connect(db_path)
        try:
            count = connection.execute("SELECT COUNT(*) FROM lightning_run").fetchone()[0]
        finally:
            connection.close()

        assert count == 0
    finally:
        cleanup_files(
            db_path,
            db_path.with_name(f"{db_path.name}-wal"),
            db_path.with_name(f"{db_path.name}-shm"),
            payload_path,
        )


