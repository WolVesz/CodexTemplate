from __future__ import annotations

import json
import os
import sqlite3
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
INIT_SCRIPT = ROOT / "tools/init_lightning_telemetry.py"
RECORD_SCRIPT = ROOT / "tools/record_lightning_trace.py"
EXPORT_SCRIPT = ROOT / "tools/export_lightning_dataset.py"


def cleanup_files(*paths: Path) -> None:
    for path in paths:
        if path.exists():
            path.unlink()


def run_script(script: Path, **env_overrides: str) -> subprocess.CompletedProcess[str]:
    env = os.environ.copy()
    env.update(env_overrides)
    return subprocess.run(
        [sys.executable, str(script)],
        cwd=ROOT,
        env=env,
        capture_output=True,
        text=True,
        check=False,
    )


def test_init_lightning_telemetry_creates_database() -> None:
    db_path = ROOT / ".codex/state/test_lightning_events.sqlite"
    cleanup_files(
        db_path,
        db_path.with_name(f"{db_path.name}-wal"),
        db_path.with_name(f"{db_path.name}-shm"),
    )

    try:
        result = run_script(
            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_events.sqlite",
        )

        assert result.returncode == 0
        assert db_path.exists()
    finally:
        cleanup_files(
            db_path,
            db_path.with_name(f"{db_path.name}-wal"),
            db_path.with_name(f"{db_path.name}-shm"),
        )


def test_init_lightning_telemetry_rejects_invalid_paths() -> None:
    traversal = run_script(INIT_SCRIPT, LIGHTNING_EVENT_DB_PATH="../bad.sqlite")
    backslashes = run_script(INIT_SCRIPT, LIGHTNING_EVENT_DB_PATH=".codex\\state\\bad.sqlite")

    assert traversal.returncode != 0
    assert "must stay inside the project" in traversal.stderr or (
        "must stay inside the project" in traversal.stdout
    )
    assert backslashes.returncode != 0
    assert "must use forward slashes" in backslashes.stderr or (
        "must use forward slashes" in backslashes.stdout
    )


def test_init_lightning_telemetry_fails_on_schema_version_mismatch() -> None:
    db_path = ROOT / ".codex/state/test_lightning_mismatch.sqlite"
    cleanup_files(
        db_path,
        db_path.with_name(f"{db_path.name}-wal"),
        db_path.with_name(f"{db_path.name}-shm"),
    )

    try:
        init_result = run_script(
            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_mismatch.sqlite",
        )
        assert init_result.returncode == 0

        connection = sqlite3.connect(db_path)
        try:
            connection.execute(
                "UPDATE schema_metadata SET metadata_value = '0' "
                "WHERE metadata_key = 'schema_version'"
            )
            connection.commit()
        finally:
            connection.close()

        mismatch = run_script(
            INIT_SCRIPT,
            LIGHTNING_EVENT_DB_PATH=".codex/state/test_lightning_mismatch.sqlite",
        )
        assert mismatch.returncode != 0
        assert "expected schema version" in mismatch.stderr or (
            "expected schema version" in mismatch.stdout
        )
    finally:
        cleanup_files(
            db_path,
            db_path.with_name(f"{db_path.name}-wal"),
            db_path.with_name(f"{db_path.name}-shm"),
        )


