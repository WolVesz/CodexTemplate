# Copy this file to `.env` and fill only the values your runtime needs.
# Keep secrets out of version control.
# This project was rendered with `{{ model_provider }}` as the default provider.
# Runtime provider choices in this template are Anthropic Claude or Google Gemini.
# Codex/OpenAI compatibility here is control-plane plus `CODEX_*` model-alias support, not a third generated runtime provider.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MODEL_PROVIDER_API_KEY=

CLAUDE_DEFAULT_MODEL=
CLAUDE_SCOPE_MODEL=
CLAUDE_EXECUTION_MODEL=
CLAUDE_REVIEW_MODEL=

GEMINI_DEFAULT_MODEL=
GEMINI_SCOPE_MODEL=
GEMINI_EXECUTION_MODEL=
GEMINI_REVIEW_MODEL=

# Optional compatibility aliases for Codex-style runners.
CODEX_DEFAULT_MODEL=
CODEX_SCOPE_MODEL=
CODEX_EXECUTION_MODEL=
CODEX_REVIEW_MODEL=

AGENT_LIGHTNING_ENABLED=false
AGENT_LIGHTNING_MODE=advisory
LIGHTNING_TELEMETRY_ENABLED=false

SCOPE_MEMORY_PATH="{{ scope_memory_path }}"
REVIEW_STATE_PATH=".claude/state/review_state.sqlite"
LIGHTNING_EVENT_DB_PATH=".claude/state/lightning_events.sqlite"
LIGHTNING_DATASET_EXPORT_PATH=".claude/exports/lightning_dataset.jsonl"
