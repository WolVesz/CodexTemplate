review_scope:
  authority: .codex/config/review-scope.yaml
  trigger_derivation_ref: .codex/config/trigger-derivation.yaml
  default_mode: delta
  if_uncertain: full
  delta_targets:
    - changed files
    - directly impacted modules
    - impacted tests
  delta_thresholds:
    max_files_changed: 5
    max_total_changed_lines: 300
  manual_full_review_labels:
    - milestone
    - release-candidate
    - architecture_change
  known_change_triggers:
    - architecture_change
    - ci_workflow_changed
    - control_plane_changed
    - code_changed
    - data_contract_changed
    - database_schema_changed
    - dependency_manifest_changed
    - evaluation_logic_changed
    - explicit_milestone_marker
    - files_changed_over_threshold
    - lines_changed_over_threshold
    - lockfile_changed
    - memory_schema_changed
    - prompt_or_policy_changed
    - runtime_behavior_changed
    - security_sensitive_change
    - shared_interface_changed
    - tests_changed
    - tool_or_model_config_changed
  full_review_triggers:
    - architecture_change
    - control_plane_changed
    - files_changed_over_threshold
    - lines_changed_over_threshold
    - memory_schema_changed
    - data_contract_changed
    - dependency_manifest_changed
    - evaluation_logic_changed
    - lockfile_changed
    - ci_workflow_changed
    - database_schema_changed
    - prompt_or_policy_changed
    - shared_interface_changed
    - security_sensitive_change
    - explicit_milestone_marker
